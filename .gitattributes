# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# Force wrangler.toml to be UTF-8 without BOM
wrangler.toml text eol=lf encoding=utf-8

# Ensure these are always normalized
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
