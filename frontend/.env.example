# Google Search Console — ownership verification token (HTML tag method)
# 1. Open Search Console → Settings → Ownership verification → HTML tag
# 2. Copy the content="..." value
# 3. Add it as a GitHub secret named VITE_GOOGLE_SITE_VERIFICATION
# 4. The deploy-pages workflow injects it into index.html at build time.
# Leave empty for local dev — the meta tag is simply omitted.
VITE_GOOGLE_SITE_VERIFICATION=

# FeedbackWidget — WhatsApp number for user suggestions and bug reports
# International format without + (e.g. 590690123456 for Guadeloupe)
# When absent the widget still renders; the send button opens WhatsApp
# without a pre-set destination number.
VITE_FEEDBACK_WHATSAPP=

# Meta (Facebook) Pixel — consent-gated analytics
# Set to your numeric Pixel ID from Meta Business Manager.
# When absent the pixel is never loaded (safe default).
# The pixel fires only when the user grants analytics consent.
VITE_META_PIXEL_ID=
