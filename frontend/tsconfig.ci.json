{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,

    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,

    "allowJs": true,
    "checkJs": false,

    "types": ["node", "vite/client"]
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx"
  ]
}
