{
  "$schema": "https://railway.app/static/spec.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run install:frontend && npm run build:frontend",
    "watchPatterns": [
      "frontend/src/**",
      "backend/app/**",
      "package.json",
      "frontend/package.json"
    ]
  },
  "deploy": {
    "startCommand": "cd frontend && npm run preview",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "runtime": "v2",
    "numReplicas": 1,
    "resources": {
      "cpu": {
        "limit": 2000
      },
      "memory": {
        "limit": 1024
      }
    }
  }
}
