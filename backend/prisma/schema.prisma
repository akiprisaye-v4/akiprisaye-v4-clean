// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ===============================
/// ENUMS
/// ===============================
enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  INSTITUTION
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  EXPIRED
}

enum PriceInterval {
  MONTH
  YEAR
}

enum UserRole {
  USER
  ADMIN
  INSTITUTION
}

enum ProductSource {
  MANUAL
  OCR
  OPENFOODFACTS
  OPENPRICES
  CITIZEN
}

enum ProductStatus {
  PENDING_REVIEW
  VALIDATED
  REJECTED
  MERGED
}

/// ===============================
/// MODELS
/// ===============================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)

  subscription           Subscription?
  priceAlerts            PriceAlert[]
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  gamification           UserGamification?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  plan        SubscriptionPlan
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  externalRef String? /// (option Stripe, extensible plus tard)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Price {
  id          String           @id @default(cuid())
  plan        SubscriptionPlan
  interval    PriceInterval
  amountCents Int /// Stocké en centimes (990 = 9.90€)
  currency    String           @default("EUR")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([plan, interval])
}

/// ===============================
/// PRODUCT SYNC MODELS
/// ===============================
model Product {
  id              String        @id @default(cuid())
  ean             String?       @unique
  name            String
  normalizedName  String
  brand           String?
  category        String?
  quantity        String?
  imageUrl        String?
  nutriscoreGrade String?
  ecoscoreGrade   String?
  source          ProductSource
  status          ProductStatus @default(PENDING_REVIEW)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  validatedAt     DateTime?
  validatedBy     String?
  
  prices          ProductPrice[]
  
  @@index([normalizedName])
  @@index([status])
  @@index([ean])
}

model ProductPrice {
  id              String   @id @default(cuid())
  productId       String
  productCode     String?
  price           Float
  currency        String   @default("EUR")
  storeId         String?
  locationOsmId   String?
  territory       String?
  date            DateTime
  source          String
  createdAt       DateTime @default(now())
  
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@index([productId])
  @@index([date])
}

model SyncLog {
  id              String    @id @default(cuid())
  source          String
  startedAt       DateTime
  completedAt     DateTime?
  status          String
  itemsProcessed  Int       @default(0)
  itemsCreated    Int       @default(0)
  itemsUpdated    Int       @default(0)
  itemsSkipped    Int       @default(0)
  errors          Json?
  
  @@index([source])
  @@index([startedAt])
}
