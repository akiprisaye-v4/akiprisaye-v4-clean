generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ===============================
/// ENUMS
/// ===============================
enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  INSTITUTION
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  EXPIRED
}

enum PriceInterval {
  MONTH
  YEAR
}

enum UserRole {
  USER
  ADMIN
  INSTITUTION
}

enum PriceSource {
  OCR_TICKET
  OFFICIAL_API
  OPEN_PRICES
  MANUAL_ENTRY
  CROWDSOURCED
  SCRAPING_AUTHORIZED
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  DISPUTED
}

enum VerificationAction {
  CONFIRM
  DISPUTE
  UPDATE
}

enum AnomalyType {
  SUDDEN_INCREASE
  SUDDEN_DECREASE
  OUTLIER_HIGH
  OUTLIER_LOW
  SHRINKFLATION
  INCONSISTENT_REPORT
  STALE_DATA
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnomalyStatus {
  PENDING
  CONFIRMED
  DISMISSED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionTier {
  FREE
  CITIZEN_PREMIUM
  SME
  BUSINESS_PRO
  INSTITUTIONAL
}

enum ApiPermission {
  READ_PRICES
  WRITE_PRICES
  READ_STORES
  WRITE_STORES
  READ_PRODUCTS
  WRITE_PRODUCTS
  ADMIN
}

/// ===============================
/// MODELS
/// ===============================
model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  passwordHash     String
  role             UserRole         @default(USER)
  isActive         Boolean          @default(true)
  subscriptionTier SubscriptionTier @default(FREE)
  lastLogin        DateTime?

  subscription       Subscription?
  priceVerifications PriceVerification[]
  refreshTokens      RefreshToken[]
  apiKeys            ApiKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  plan        SubscriptionPlan
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  externalRef String? /// (option Stripe, extensible plus tard)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Price {
  id          String           @id @default(cuid())
  plan        SubscriptionPlan
  interval    PriceInterval
  amountCents Int /// Stocké en centimes (990 = 9.90€)
  currency    String           @default("EUR")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([plan, interval])
}

/// Product Price Observation (Prix produit)
model ProductPrice {
  id                  String              @id @default(cuid())
  productId           String
  storeId             String
  price               Float
  currency            String              @default("EUR")
  
  // Traçabilité
  source              PriceSource
  observedAt          DateTime
  reportedBy          String?
  proofUrl            String?
  
  // Vérification
  verificationStatus  VerificationStatus  @default(UNVERIFIED)
  verificationCount   Int                 @default(0)
  lastVerifiedAt      DateTime?
  
  // Confiance
  confidenceScore     Int                 @default(0)
  confidenceFactors   Json?
  
  // Métadonnées
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  isActive            Boolean             @default(true)
  
  verifications       PriceVerification[]
  anomalies           PriceAnomaly[]
  
  @@index([productId])
  @@index([storeId])
  @@index([observedAt])
  @@index([confidenceScore])
  @@index([verificationStatus])
}

model PriceVerification {
  id          String              @id @default(cuid())
  priceId     String
  userId      String
  action      VerificationAction
  comment     String?
  createdAt   DateTime            @default(now())
  
  price       ProductPrice        @relation(fields: [priceId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([priceId])
  @@index([userId])
  @@unique([priceId, userId])
}

model PriceAnomaly {
  id            String        @id @default(cuid())
  priceId       String
  productId     String
  storeId       String
  anomalyType   AnomalyType
  severity      Severity
  
  reportedPrice Float
  expectedPrice Float
  deviation     Float
  
  status        AnomalyStatus @default(PENDING)
  resolvedAt    DateTime?
  resolvedBy    String?
  resolution    String?
  context       Json?
  
  createdAt     DateTime      @default(now())
  
  price         ProductPrice  @relation(fields: [priceId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([severity])
  @@index([productId])
  @@index([storeId])
}

model ProductUpdate {
  id            String        @id @default(cuid())
  productId     String
  field         String
  oldValue      String?
  newValue      String
  source        String
  autoApplied   Boolean       @default(false)
  reviewStatus  ReviewStatus  @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  
  @@index([productId])
  @@index([reviewStatus])
  @@index([createdAt])
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([expiresAt])
}

model ApiKey {
  id          String         @id @default(cuid())
  key         String         @unique
  keyHash     String         @unique
  name        String
  userId      String
  permissions ApiPermission[]
  isActive    Boolean        @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([keyHash])
  @@index([isActive])
}

/// ===============================
/// RECEIPT OCR IMPORT MODULE
/// Added: receipt ingestion pipeline
/// ===============================

model Store {
  id             String   @id @default(cuid())
  normalizedName String
  rawName        String?
  brand          String?
  company        String?
  siret          String?
  phone          String?
  address        String?
  postalCode     String?
  city           String?
  territory      String   /// TerritoryCode lowercase (gp, mq, ...)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipts     Receipt[]
  observations PriceObservation[]

  @@unique([normalizedName, territory])
  @@index([territory])
  @@index([normalizedName])
}

model Receipt {
  id              String   @id @default(cuid())
  source          String   @default("ocr_ticket")
  storeId         String
  territory       String
  receiptDate     DateTime
  receiptTime     String?
  currency        String   @default("EUR")
  itemsCount      Int?
  linesCount      Int?
  subtotalHt      Float?
  totalTtc        Float
  rawOcrText      String?  @db.Text
  confidenceScore Int      @default(0)
  needsReview     Boolean  @default(false)
  checksum        String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store        Store              @relation(fields: [storeId], references: [id])
  items        ReceiptItem[]
  observations PriceObservation[]

  @@index([storeId])
  @@index([territory])
  @@index([receiptDate])
}

model ReceiptItem {
  id               String  @id @default(cuid())
  receiptId        String
  lineIndex        Int
  rawLabel         String
  normalizedLabel  String?
  brand            String?
  category         String?
  subcategory      String?
  quantity         Float?
  unit             String?
  packageSizeValue Float?
  packageSizeUnit  String?
  unitPrice        Float?
  totalPrice       Float
  vatRate          Float?
  barcode          String?
  productId        String?
  confidenceScore  Int     @default(0)
  needsReview      Boolean @default(false)
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipt      Receipt           @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product      Product?          @relation(fields: [productId], references: [id])
  observations PriceObservation[]

  @@index([receiptId])
  @@index([productId])
}

model Product {
  id                   String  @id @default(cuid())
  productKey           String  @unique
  displayName          String
  rawLabel             String
  normalizedLabel      String
  brand                String?
  category             String?
  subcategory          String?
  barcode              String? @unique
  packageSizeValue     Float?
  packageSizeUnit      String?
  primaryImageUrl      String?
  imageSource          String?
  imageSourceType      String?
  imageConfidenceScore Int?
  imageNeedsReview     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receiptItems   ReceiptItem[]
  images         ProductImage[]
  observations   PriceObservation[]
  historyMonthly PriceHistoryMonthly[]
  historyYearly  PriceHistoryYearly[]

  @@index([productKey])
  @@index([category])
  @@index([barcode])
}

model ProductImage {
  id              String  @id @default(cuid())
  productId       String
  imageUrl        String
  thumbnailUrl    String?
  pageUrl         String?
  source          String
  sourceType      String
  confidenceScore Int     @default(0)
  isPrimary       Boolean @default(false)
  needsReview     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isPrimary])
}

model PriceObservation {
  id               String   @id @default(cuid())
  source           String   @default("receipt_ocr")
  receiptId        String?
  receiptItemId    String?
  productId        String?
  territory        String
  storeId          String?
  storeLabel       String
  observedAt       DateTime
  productLabel     String
  normalizedLabel  String
  category         String?
  brand            String?
  barcode          String?
  quantity         Float?
  unit             String?
  packageSizeValue Float?
  packageSizeUnit  String?
  price            Float
  currency         String   @default("EUR")
  confidenceScore  Int      @default(0)
  needsReview      Boolean  @default(false)

  createdAt DateTime @default(now())

  receipt     Receipt?     @relation(fields: [receiptId], references: [id])
  receiptItem ReceiptItem? @relation(fields: [receiptItemId], references: [id])
  product     Product?     @relation(fields: [productId], references: [id])
  store       Store?       @relation(fields: [storeId], references: [id])

  @@index([productId, territory, observedAt])
  @@index([territory, observedAt])
  @@index([storeId])
  @@index([needsReview])
}

model PriceHistoryMonthly {
  id                String   @id @default(cuid())
  productId         String
  territory         String
  year              Int
  month             Int
  avgPrice          Float
  minPrice          Float
  maxPrice          Float
  observationsCount Int      @default(0)
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, territory, year, month])
  @@index([productId, territory, year, month])
}

model PriceHistoryYearly {
  id                String   @id @default(cuid())
  productId         String
  territory         String
  year              Int
  avgPrice          Float
  minPrice          Float
  maxPrice          Float
  observationsCount Int      @default(0)
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, territory, year])
  @@index([productId, territory, year])
}

model ReviewQueueEntry {
  id          String   @id @default(cuid())
  entityType  String   /// "receipt" | "receipt_item" | "product" | "product_image"
  entityId    String
  reason      String
  payloadJson Json?
  status      String   @default("pending") /// pending | in_review | approved | rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, entityType])
  @@index([entityId])
}

model PriceAlertEvent {
  id          String   @id @default(cuid())
  productId   String
  territory   String
  eventType   String   /// "new_low" | "significant_drop" | "significant_rise"
  oldPrice    Float?
  newPrice    Float
  dropPercent Float?
  storeLabel  String?
  observedAt  DateTime
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([productId, territory])
  @@index([processed])
}
