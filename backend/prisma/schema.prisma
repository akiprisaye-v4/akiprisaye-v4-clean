generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ===============================
/// ENUMS
/// ===============================
enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  INSTITUTION
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  EXPIRED
}

enum PriceInterval {
  MONTH
  YEAR
}

enum UserRole {
  USER
  ADMIN
  INSTITUTION
}

enum PriceSource {
  OCR_TICKET
  OFFICIAL_API
  OPEN_PRICES
  MANUAL_ENTRY
  CROWDSOURCED
  SCRAPING_AUTHORIZED
}

enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  DISPUTED
}

enum VerificationAction {
  CONFIRM
  DISPUTE
  UPDATE
}

enum AnomalyType {
  SUDDEN_INCREASE
  SUDDEN_DECREASE
  OUTLIER_HIGH
  OUTLIER_LOW
  SHRINKFLATION
  INCONSISTENT_REPORT
  STALE_DATA
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnomalyStatus {
  PENDING
  CONFIRMED
  DISMISSED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionTier {
  FREE
  CITIZEN_PREMIUM
  SME
  BUSINESS_PRO
  INSTITUTIONAL
}

enum ApiPermission {
  READ_PRICES
  WRITE_PRICES
  READ_STORES
  WRITE_STORES
  READ_PRODUCTS
  WRITE_PRODUCTS
  ADMIN
}

/// ===============================
/// MODELS
/// ===============================
model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  passwordHash     String
  role             UserRole         @default(USER)
  isActive         Boolean          @default(true)
  subscriptionTier SubscriptionTier @default(FREE)
  lastLogin        DateTime?

  subscription       Subscription?
  priceVerifications PriceVerification[]
  refreshTokens      RefreshToken[]
  apiKeys            ApiKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  plan        SubscriptionPlan
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  externalRef String? /// (option Stripe, extensible plus tard)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Price {
  id          String           @id @default(cuid())
  plan        SubscriptionPlan
  interval    PriceInterval
  amountCents Int /// Stocké en centimes (990 = 9.90€)
  currency    String           @default("EUR")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([plan, interval])
}

/// Product Price Observation (Prix produit)
model ProductPrice {
  id                  String              @id @default(cuid())
  productId           String
  storeId             String
  price               Float
  currency            String              @default("EUR")
  
  // Traçabilité
  source              PriceSource
  observedAt          DateTime
  reportedBy          String?
  proofUrl            String?
  
  // Vérification
  verificationStatus  VerificationStatus  @default(UNVERIFIED)
  verificationCount   Int                 @default(0)
  lastVerifiedAt      DateTime?
  
  // Confiance
  confidenceScore     Int                 @default(0)
  confidenceFactors   Json?
  
  // Métadonnées
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  isActive            Boolean             @default(true)
  
  verifications       PriceVerification[]
  anomalies           PriceAnomaly[]
  
  @@index([productId])
  @@index([storeId])
  @@index([observedAt])
  @@index([confidenceScore])
  @@index([verificationStatus])
}

model PriceVerification {
  id          String              @id @default(cuid())
  priceId     String
  userId      String
  action      VerificationAction
  comment     String?
  createdAt   DateTime            @default(now())
  
  price       ProductPrice        @relation(fields: [priceId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([priceId])
  @@index([userId])
  @@unique([priceId, userId])
}

model PriceAnomaly {
  id            String        @id @default(cuid())
  priceId       String
  productId     String
  storeId       String
  anomalyType   AnomalyType
  severity      Severity
  
  reportedPrice Float
  expectedPrice Float
  deviation     Float
  
  status        AnomalyStatus @default(PENDING)
  resolvedAt    DateTime?
  resolvedBy    String?
  resolution    String?
  context       Json?
  
  createdAt     DateTime      @default(now())
  
  price         ProductPrice  @relation(fields: [priceId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([severity])
  @@index([productId])
  @@index([storeId])
}

model ProductUpdate {
  id            String        @id @default(cuid())
  productId     String
  field         String
  oldValue      String?
  newValue      String
  source        String
  autoApplied   Boolean       @default(false)
  reviewStatus  ReviewStatus  @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  
  @@index([productId])
  @@index([reviewStatus])
  @@index([createdAt])
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([expiresAt])
}

model ApiKey {
  id          String         @id @default(cuid())
  key         String         @unique
  keyHash     String         @unique
  name        String
  userId      String
  permissions ApiPermission[]
  isActive    Boolean        @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([keyHash])
  @@index([isActive])
}
