# Application Version
APP_VERSION=1.3.0

# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project credentials

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Feature Flags
# Price Comparison v1.4.0 (default: false)
VITE_FEATURE_PRICE_COMPARISON=false

# Ingredient Evolution v1.7.0 (default: false)
VITE_FEATURE_INGREDIENT_EVOLUTION=false

# Open Data Export v1.8.0 (default: false)
VITE_FEATURE_OPEN_DATA_EXPORT=false

# Territorial Aggregation v1.9.0 (default: false)
VITE_FEATURE_TERRITORIAL_AGGREGATION=false

# Product Search Engine v2.0 (default: false)
VITE_FEATURE_PRODUCT_SEARCH=false
